# ─────────────────────────────────────────────────────────────────────────────
# StressSense Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your own values
#   3. NEVER commit .env to version control (it's in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_APP=app.py
FLASK_ENV=development

# ── Security ──────────────────────────────────────────────────────────────────
# Generate strong random secrets in production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-flask-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — no setup required):
DATABASE_URL=sqlite:///database/database.db

# MySQL example (uncomment and fill in for production):
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/stresssense_db

# PostgreSQL example (Render/Railway):
# DATABASE_URL=postgresql://username:password@host:5432/stresssense_db

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── File Uploads ──────────────────────────────────────────────────────────────
MAX_CONTENT_LENGTH=16777216

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
